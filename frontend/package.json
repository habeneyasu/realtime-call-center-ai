{
  "name": "call-center-ai-dashboard",
  "version": "1.0.0",
  "description": "Real-time call center AI dashboard with live transcription",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
